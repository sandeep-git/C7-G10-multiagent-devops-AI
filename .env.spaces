# ──────────────────────────────────────────────────────────────────
# Hugging Face Spaces — Secret Variables
# Add each of these in your Space Settings → Variables and Secrets
# DO NOT commit real values — add them via the HF Spaces UI
# ──────────────────────────────────────────────────────────────────

# REQUIRED — OpenRouter API key (get from openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# OPTIONAL — change the model (default: anthropic/claude-sonnet-4-5)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# OPTIONAL — Jira integration (real ticket creation)
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=OPS

# OPTIONAL — Slack integration
SLACK_CHANNEL=#incidents

# Internal — set automatically by supervisord, do not change
BACKEND_URL=http://localhost:8000
