# Backend — OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=DevOps Incident Suite

# ChromaDB path (relative to project root)
CHROMA_PATH=./chroma_db

# Jira integration — REAL API
# JIRA_BASE_URL   : your site URL, e.g. https://yourname.atlassian.net
# JIRA_EMAIL      : the email you used to sign up at atlassian.com
# JIRA_API_TOKEN  : from https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_PROJECT_KEY: the short key of your project, e.g. OPS or INC
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=OPS

# Slack integration — REAL API
# SLACK_WEBHOOK_URL: from api.slack.com/apps → Incoming Webhooks → Add Webhook
# SLACK_BOT_TOKEN  : from api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
# SLACK_CHANNEL    : channel to post to, e.g. #incidents
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL=#incidents

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
